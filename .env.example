# ============================================
# AiRefCheck - Environment Variables
# ============================================
# Bu dosyayı .env olarak kopyalayıp doldurun
# cp .env.example .env
# ============================================

# ---- Uygulama ----
NODE_ENV=development
APP_PORT=3001
APP_URL=http://localhost:3001

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ---- Veritabanı ----
DATABASE_URL=postgresql://airefcheck:airefcheck@localhost:5432/airefcheck?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_SALT_ROUNDS=12

# ---- OAuth2 (Opsiyonel) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# ---- Dosya Yükleme ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600
FILE_RETENTION_DAYS=30

# ---- Dış API'ler ----
CROSSREF_API_URL=https://api.crossref.org
CROSSREF_MAILTO=your-email@example.com
SEMANTIC_SCHOLAR_API_URL=https://api.semanticscholar.org
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_API_URL=https://api.openalex.org
OPENALEX_EMAIL=your-email@example.com
GOOGLE_SCHOLAR_EMAIL=your-email@example.com
DERGIPARK_BASE_URL=https://dergipark.org.tr
TR_DIZIN_BASE_URL=https://trdizin.gov.tr
YOK_TEZ_BASE_URL=https://tez.yok.gov.tr
PUBMED_API_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
ARXIV_API_URL=http://export.arxiv.org/api/query
DOI_RESOLVER_URL=https://doi.org/api/handles

# ---- Python NLP Servisi ----
NLP_SERVICE_URL=http://localhost:8001

# ---- Loglama ----
LOG_LEVEL=info
LOG_FORMAT=json

# ---- Önbellekleme ----
API_CACHE_TTL=604800
API_CACHE_ENABLED=true

# ---- Rate Limiting ----
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
