{
  "name": "@airefcheck/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@airefcheck/shared": "workspace:*",
    "@prisma/client": "^5.16.0",
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.0",
    "socket.io": "^4.7.0",
    "bullmq": "^5.8.0",
    "ioredis": "^5.4.0",
    "zod": "^3.23.0",
    "bcrypt": "^5.1.0",
    "jose": "^5.6.0",
    "axios": "^1.7.0",
    "winston": "^3.13.0",
    "pdf-parse": "^1.1.0",
    "mammoth": "^1.8.0",
    "bibtex-parse-js": "^0.0.24",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.0"
