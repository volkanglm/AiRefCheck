  "prisma": {
    "schema": "../../prisma/schema.prisma",
    "seed": "tsx ../../prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/bcrypt": "^5.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "vitest": "^1.6.0",
